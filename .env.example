# .env.example — commit this file. NEVER commit the real .env.
# Copy to `.env` and fill in the values:
#   cp .env.example .env && $EDITOR .env
#
# ADD §6.4 defines this as the ONLY credential ingress.
# `tests/test_env_contract.py` enforces that .env.example and .env have
# identical key sets (values may differ).

# ------------ API credentials (required) ------------

# FRED / ALFRED data API
# Register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Nasdaq Data Link (formerly Quandl) — for NASDAQXNDX total-return series
# Register at https://data.nasdaq.com/sign-up
NASDAQ_DL_API_KEY=

# CBOE data (for VXN / VIX / VXV historical if not using public CSV mirror).
# If blank, the code falls back to the public historical CSV mirror pinned
# in src/data_contract/cboe_client.py (still strict-PIT per vintage_registry).
CBOE_TOKEN=

# ------------ Runtime ------------

# Container timezone (affects Friday-close anchor resolution).
# MUST stay America/New_York in production (SRD §1).
TZ=America/New_York

# Log verbosity: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# ------------ Execution mode (consumed by docker-compose) ------------

# weekly | backtest | train | verify | health
RUN_MODE=weekly

# YYYY-MM-DD or "auto" (= most recent Friday close in TZ above).
AS_OF=auto

# Tag of the engine image to run.
IMAGE_TAG=dev

# ------------ Optional: observability ------------

# Extra context for structured logs
DEPLOY_ENV=local
